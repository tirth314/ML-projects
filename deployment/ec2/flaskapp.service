[Unit]
Description=Gunicorn instance to serve Flask student-score app
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/ML-projects
Environment="PATH=/home/ec2-user/ML-projects/venv/bin"
ExecStart=/home/ec2-user/ML-projects/venv/bin/gunicorn --workers 3 --bind 0.0.0.0:8000 app:application
Restart=always

[Install]
WantedBy=multi-user.target